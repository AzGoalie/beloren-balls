[bootstrap]
main_collection = /main/main.collectionc

[script]
shared_state = 1

[display]
width = 960
height = 640
high_dpi = 1

[android]
input_method = HiddenInputField

[physics]
gravity_y = 0.0
scale = 0.01

[html5]
scale_mode = no_scale
show_made_with_defold = 0
show_console_banner = 0
show_fullscreen_button = 0
cssfile = /builtins/manifests/web/dark_theme.css

[project]
title = Beloren Balls

